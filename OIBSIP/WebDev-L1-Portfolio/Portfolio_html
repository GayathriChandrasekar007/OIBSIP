<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Personal portfolio for Gayathri showcasing skills, projects, and contact information.">
    <title>Gayathri | Portfolio</title>
    <link rel="stylesheet" href="portfolio.css">
</head>
<body>
    <header class="site-header">
        <nav class="nav-bar">
            <div class="nav-brand">Gayathri</div>
            <ul class="nav-links">
                <li><a href="#home">Home</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#skills">Skills</a></li>
                <li><a href="#projects">Projects</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>
    </header>

    <main>
        <section id="home" class="hero-section">
            <div class="hero-content">
                <p class="eyebrow">Personal Portfolio</p>
                <h1>Hi, I'm Gayathri</h1>
                <p class="hero-copy">A passionate Web Developer & Designer building polished, responsive websites with clean HTML and CSS.</p>
                <div class="hero-actions">
                    <a class="btn btn-primary" href="#projects">View Projects</a>
                    <a class="btn btn-secondary" href="#contact">Contact Me</a>
                </div>
            </div>
            <div class="hero-avatar">
                <div class="avatar-placeholder">G</div>
                <p class="avatar-label">Web Development & Designing</p>
            </div>
        </section>

        <section id="about" class="about-section section-block">
            <div class="section-heading">
                <p class="section-label">About Me</p>
                <h2>Who I Am</h2>
            </div>
            <p class="section-text">I am a creative web developer with a strong eye for design. I love crafting clean, modern websites that help brands stand out and communicate clearly. My work focuses on responsive layouts, thoughtful typography, and polished user experiences.</p>
        </section>

        <section id="skills" class="skills-section section-block">
            <div class="section-heading">
                <p class="section-label">Skills</p>
                <h2>What I Can Do</h2>
            </div>
            <div class="skills-grid">
                <div class="skill-card">HTML5</div>
                <div class="skill-card">CSS3</div>
                <div class="skill-card">Responsive Design</div>
                <div class="skill-card">Flexbox & Grid</div>
                <div class="skill-card">Branding</div>
                <div class="skill-card">UI Design</div>
                <div class="skill-card">Accessibility</div>
                <div class="skill-card">Version Control</div>
            </div>
        </section>

        <section id="projects" class="projects-section section-block">
            <div class="section-heading">
                <p class="section-label">Projects</p>
                <h2>Recent Work</h2>
            </div>
            <div class="projects-grid">
                <article class="project-card">
                    <div class="project-tag">Design</div>
                    <h3 class="project-title">Creative Agency Landing Page</h3>
                    <p class="project-description">A responsive landing page prototype for a creative agency, featuring a bold hero, service cards, and a contact section.</p>
                    <a class="project-link" href="#">GitHub placeholder</a>
                </article>
                <article class="project-card">
                    <div class="project-tag">Portfolio</div>
                    <h3 class="project-title">Personal Portfolio Website</h3>
                    <p class="project-description">A polished portfolio template with smooth navigation, project showcases, and a clean visual style.</p>
                    <a class="project-link" href="#">GitHub placeholder</a>
                </article>
            </div>
        </section>

        <section id="contact" class="contact-section section-block">
            <div class="section-heading">
                <p class="section-label">Contact</p>
                <h2>Let's Connect</h2>
            </div>
            <div class="contact-grid">
                <div class="contact-card">
                    <h3>Name</h3>
                    <p>Gayathri</p>
                </div>
                <div class="contact-card">
                    <h3>Email</h3>
                    <p><a href="mailto:gayathri@example.com">gayathri@example.com</a></p>
                </div>
                <div class="contact-card">
                    <h3>Links</h3>
                    <div class="contact-links">
                        <a href="#" aria-label="LinkedIn">LinkedIn</a>
                        <a href="#" aria-label="GitHub">GitHub</a>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer class="site-footer">
        <p>© 2026 Gayathri. Built with HTML & CSS.</p>
    </footer>
</body>
</html>
