const inputValue = document.getElementById('value');
const fromUnit = document.getElementById('fromUnit');
const convertBtn = document.getElementById('convertBtn');
const errorMessage = document.getElementById('errorMessage');

const celsiusResult = document.getElementById('celsiusResult');
const fahrenheitResult = document.getElementById('fahrenheitResult');
const kelvinResult = document.getElementById('kelvinResult');

function showError(message) {
    errorMessage.textContent = message;
    celsiusResult.textContent = '--';
    fahrenheitResult.textContent = '--';
    kelvinResult.textContent = '--';
}

function clearError() {
    errorMessage.textContent = '';
}

function convertTemperature(value, unit) {
    let celsius;

    if (unit === 'c') {
        celsius = value;
    } else if (unit === 'f') {
        celsius = (value - 32) * 5 / 9;
    } else if (unit === 'k') {
        celsius = value - 273.15;
    }

    if (celsius < -273.15) {
        showError('Temperature cannot be below absolute zero (-273.15°C).');
        return;
    }

    const fahrenheit = (celsius * 9 / 5) + 32;
    const kelvin = celsius + 273.15;

    celsiusResult.textContent = `${celsius.toFixed(2)} °C`;
    fahrenheitResult.textContent = `${fahrenheit.toFixed(2)} °F`;
    kelvinResult.textContent = `${kelvin.toFixed(2)} K`;
    clearError();
}

convertBtn.addEventListener('click', () => {
    const valueText = inputValue.value.trim();

    if (valueText === '') {
        showError('Please enter a temperature value.');
        return;
    }

    const value = Number(valueText);

    if (Number.isNaN(value)) {
        showError('Please enter a valid numeric value.');
        return;
    }

    convertTemperature(value, fromUnit.value);
});
